#!/usr/bin/env python3
"""
Recon-burst detector - "someone is looking around."

The vector-independent detector. It does not care how the intruder got
in (stolen SSH key, reverse shell, exec channel, an insider). It watches
what auditd records everyone actually DOING and fires when a single
session runs a burst of enumeration commands in a short window - the
universal first move after any breach: who am I, what is this box, where
is the data, how do I persist.

Implementation: streams /var/log/audit/audit.log directly via `tail -F`
and correlates each execve's audit session id (ses) with its command.
We deliberately do NOT shell out to `ausearch` - it has been observed to
hang on some hosts, which would silently starve this detector.

Grouping is by audit session id, so concurrent sessions do not pool into
a false burst. Tuning lives in config: recon_threshold,
recon_window_seconds, recon_patterns. Start in alert mode; whitelist
your own admin IPs via the shared whitelist. Audit records don't carry a
source IP, so this detector alerts (and in active mode terminates the
offending login session) but does not IP-block on its own.
"""

import re
import subprocess
import sys
import time

sys.path.insert(0, "/opt/watcher")
import sentinel_lib as S  # noqa: E402

ENABLED = S.getbool("recon", "enabled", True)
WINDOW = S.getint("recon", "window_seconds", 45)
THRESHOLD = S.getint("recon", "threshold", 4)

DEFAULT_PATTERNS = ",".join([
    r"\bwhoami\b", r"\bid\b", r"\buname\b", r"/etc/passwd", r"/etc/shadow",
    r"sudo\s+-l", r"crontab\s+-l", r"\bnetstat\b", r"\bss\s+-",
    r"\bifconfig\b", r"\bip\s+a", r"\.ssh", r"\bhistory\b",
    r"ps\s+aux", r"ps\s+-ef", r"/etc/os-release", r"lsb_release",
    r"\bwget\b", r"\bcurl\b", r"\bnmap\b", r"\bmasscan\b",
    r"\bprintenv\b", r"\benv\b", r"\bmount\b", r"\blsblk\b",
    r"\blast\b", r"\bwho\b", r"docker\s+ps", r"find\s+/.*-perm",
    r"cat\s+/root", r"cat\s+.*/\.aws", r"cat\s+.*/\.env",
])
PATTERNS = [re.compile(p) for p in
            S.getlist("recon", "recon_patterns", DEFAULT_PATTERNS)]

# session id -> {"hits": [(epoch, pattern)], "alerted": epoch, "user": str}
_sessions: dict[str, dict] = {}


def handle(ses: str, auid: str | None, cmd: str) -> None:
    matched = next((p.pattern for p in PATTERNS if p.search(cmd)), None)
    if not matched:
        return
    now = time.time()
    state = _sessions.setdefault(
        ses, {"hits": [], "alerted": 0.0, "user": auid or "unknown"})
    # distinct indicators only, so `id; id; id` is not a burst
    if matched not in [p for (_, p) in state["hits"]]:
        state["hits"].append((now, matched))
    # prune to the sliding window
    state["hits"] = [(t, p) for (t, p) in state["hits"] if now - t <= WINDOW]

    if len(state["hits"]) >= THRESHOLD and now - state["alerted"] > WINDOW:
        state["alerted"] = now
        indicators = ", ".join(p for (_, p) in state["hits"])
        S.respond(
            "recon-burst",
            f"Session {ses} (auid {state['user']}) ran {len(state['hits'])} "
            f"distinct enumeration commands in <{WINDOW}s.\n"
            f"Indicators: {indicators}",
            user=(state["user"] if state["user"] != "unknown" else None),
            session_id=ses,
            extra=f"audit_session={ses}",
        )

    # bound memory: drop sessions with no recent hits
    if len(_sessions) > 4096:
        for sid in [k for k, v in _sessions.items() if not v["hits"]]:
            _sessions.pop(sid, None)


def follow_audit_log() -> None:
    proc = subprocess.Popen(
        ["tail", "-Fn0", S.AUDIT_LOG],
        stdout=subprocess.PIPE,
        text=True,
    )
    assert proc.stdout is not None
    for ses, auid, cmd in S.iter_audit_execve(proc.stdout):
        try:
            handle(ses, auid, cmd)
        except Exception:
            pass  # a bad event must never kill the stream


if __name__ == "__main__":
    if not ENABLED:
        sys.exit(0)
    S.notify(f"Recon-burst detector started on {S.HOST} "
             f"(threshold {THRESHOLD}/{WINDOW}s, mode {S.MODE}).")
    while True:
        try:
            follow_audit_log()
        except Exception:
            time.sleep(2)  # tail died; restart the stream
