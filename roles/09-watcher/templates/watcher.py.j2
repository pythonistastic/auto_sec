#!/usr/bin/env python3
"""
Behavioral login pattern watcher (SSH tripwire second factor).

Valid users know an unwritten rule: within N seconds of an interactive
SSH login they run a command containing the secret pattern. A session
whose commands never match is flagged as a likely credential-theft
intrusion.

This is ONE detector among several. It only sees SSH *logins*, so it
cannot see reverse shells (revshell_scan.py) or post-exploit recon from
non-login sessions (recon_watch.py). Those run alongside it.

Sessions are tracked individually via systemd-logind / audit session
IDs, so a valid user logged in at the same time as an intruder on the
same account cannot vouch for the intruder. Non-interactive sessions
(scp, rsync, ansible, git) have no TTY and are skipped by default.

Reads:
  /var/log/auth.log                  new session detection
  loginctl                           session identity (TTY, remote IP)
  ausearch -k exec_log --session N   per-session executed commands
"""

import os
import re
import subprocess
import sys
import threading
import time

sys.path.insert(0, "/opt/watcher")
import sentinel_lib as S  # noqa: E402

PATTERN = S.get("watcher", "pattern", fallback="").strip()
WINDOW = S.getint("watcher", "window_seconds", 60)
SKIP_NON_INTERACTIVE = S.getbool("watcher", "skip_non_interactive", True)

LOGIN_RE = re.compile(
    r"Accepted \w+ for (?P<user>\S+) from (?P<ip>\S+) port (?P<port>\d+)"
)

_claimed: set[str] = set()
_claimed_lock = threading.Lock()


def session_property(session_id: str, prop: str) -> str:
    return S.run(
        ["loginctl", "show-session", session_id, "-p", prop, "--value"]
    ).strip()


def session_is_interactive(session_id: str) -> bool:
    """
    True only for a human shell login. The reliable signal is the
    presence of a LOGIN SHELL (argv[0] begins with '-', e.g. '-bash')
    among the session's processes. sshd starts a login shell only for
    an interactive login; `ssh host "cmd"` runs `bash -c "cmd"` (and,
    with sudo, `sudo ...`) - never a login shell. This is not fooled by
    sudo's `Defaults use_pty`, which a plain TTY check is (verified on
    Ubuntu 22.04: automation sessions get a pty yet have no login shell).

    Processes are tied to the session by /proc/<pid>/sessionid, which
    equals the logind session's Audit id.
    """
    audit_ses = session_property(session_id, "Audit")
    if not audit_ses or not audit_ses.isdigit():
        return False
    for entry in os.listdir("/proc"):
        if not entry.isdigit():
            continue
        try:
            with open(f"/proc/{entry}/sessionid") as fh:
                if fh.read().strip() != audit_ses:
                    continue
            with open(f"/proc/{entry}/cmdline", "rb") as fh:
                if fh.read().split(b"\x00", 1)[0].startswith(b"-"):
                    return True
        except (OSError, ValueError):
            continue
    return False


def find_new_session(user: str, ip: str, deadline: float) -> str | None:
    while time.time() < deadline:
        out = S.run(["loginctl", "list-sessions", "--no-legend"])
        for line in out.splitlines():
            parts = line.split()  # SESSION UID USER SEAT ...
            if len(parts) < 3:
                continue
            sid, sess_user = parts[0], parts[2]
            if sess_user != user:
                continue
            if session_property(sid, "RemoteHost") != ip:
                continue
            with _claimed_lock:
                if sid in _claimed:
                    continue
                _claimed.add(sid)
            return sid
        time.sleep(1)
    return None


def session_commands(session_id: str) -> list[str]:
    # Read straight from the audit log (never ausearch - it can hang).
    audit_ses = session_property(session_id, "Audit") or session_id
    return [cmd for (ses, _auid, cmd) in S.snapshot_execve()
            if ses == audit_ses]


def check_session(user: str, ip: str, login_time: float) -> None:
    if S.is_whitelisted(ip):
        return
    session_id = find_new_session(
        user, ip, deadline=login_time + min(15, WINDOW)
    )
    if session_id:
        if SKIP_NON_INTERACTIVE and not session_is_interactive(session_id):
            # scp/rsync/ansible/git/sudo-over-ssh: not a human shell login.
            with _claimed_lock:
                _claimed.discard(session_id)
            return
        remaining = login_time + WINDOW - time.time()
        if remaining > 0:
            time.sleep(remaining)
        cmds = session_commands(session_id)
        with _claimed_lock:
            _claimed.discard(session_id)
        if any(PATTERN in c for c in cmds):
            return  # trusted session, stay silent
        preview = "; ".join(cmds[:5]) if cmds else "(no commands captured)"
        S.respond(
            "ssh-pattern-miss",
            f"Session for '{user}' from {ip} did NOT run the expected "
            f"pattern within {WINDOW}s.\nFirst commands: {preview}",
            user=user, ip=ip, session_id=session_id,
        )
    else:
        # Could not tie the login to a logind session in time. This is
        # usually a short-lived non-interactive connection (a race), not
        # an attack, and post-breach activity is caught by the revshell
        # and recon detectors. Log to journald only, never alert.
        print(
            f"[watcher] login by '{user}' from {ip} not matched to a "
            f"logind session; ignoring (likely non-interactive).",
            file=sys.stderr,
            flush=True,
        )


def follow_auth_log() -> None:
    proc = subprocess.Popen(
        ["tail", "-Fn0", "/var/log/auth.log"],
        stdout=subprocess.PIPE,
        text=True,
    )
    assert proc.stdout is not None
    for line in proc.stdout:
        m = LOGIN_RE.search(line)
        if not m:
            continue
        threading.Thread(
            target=check_session,
            args=(m.group("user"), m.group("ip"), time.time()),
            daemon=True,
        ).start()


if __name__ == "__main__":
    S.notify(
        f"Watcher started on {S.HOST} (mode: {S.MODE}, "
        f"whitelisted networks: {len(S.WHITELIST)})"
    )
    follow_auth_log()
